<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Car Details</h1>
    <p>Brand: <%= car.brand %></p>
    <p>Model: <%= car.model %></p>
    <p>Production Year: <%= car.year %></p>
    <p>Price: BD<%= car.price %></p>
    <p>Engine Size: <%= car.engineSize %>cc</p>
    <p>Transmission Type: <% if(car.isItAutomatic) {%>
       Automatic
    <% } else {%>
        Manual
    <% } %>
    </p>
    <form action="/cars/<%=car._id%>/edit" method="get">
        <button>Update Car</button>
    </form>
    <br>
    <form action="/cars/<%=car._id%>?_method=DELETE" method="post">
        <button>Delete Car</button>
    </form>

</body>
</html>